GROQ_API_KEY=gsk_여기에_키_입력

# 선택 사항 — 없으면 자동으로 DuckDuckGo(무료, 키 불필요)를 씁니다.
# BRAVE_SEARCH_API_KEY=여기에_키_입력

# 뉴스 스킬(NewsAPI.org, 무료 티어 하루 100회). 없으면 뉴스 스킬이 안내 문구를 반환합니다.
NEWSAPI_KEY=여기에_키_입력

# 이메일 스킬(Gmail SMTP). GMAIL_APP_PASSWORD는 2단계 인증 기반 "앱 비밀번호"이며
# 계정 비밀번호가 아닙니다. 없으면 이메일 스킬이 안내 문구를 반환합니다.
GMAIL_ADDRESS=여기에_Gmail_주소_입력
GMAIL_APP_PASSWORD=여기에_앱_비밀번호_입력

# WhatsApp 스킬(pywhatkit) — 선택 사항, 없으면 기본값 +82(한국)를 씁니다.
WHATSAPP_DEFAULT_COUNTRY_CODE=+82
